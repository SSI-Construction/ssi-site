{
    "name": "ssi-construction-site",
    "version": "1.0.0",
    "description": "Eleventy-powered site for SSI Construction with Netlify CMS integration",
    "scripts": {
      "build:css": "tailwindcss -i ./src/styles.css -o ./ssi_site_v2/styles.css --minify",
      "watch:css": "tailwindcss -i ./src/styles.css -o ./ssi_site_v2/styles.css --watch",
      "start": "npm run build:css && eleventy --serve",
      "build": "npm run build:css && eleventy"
    },
    "dependencies": {
        "@11ty/eleventy": "^2.0.1",
        "luxon": "^3.3.0"
    },
    "devDependencies": {
        "tailwindcss": "^3.4.19"
    }
}
