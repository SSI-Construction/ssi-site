<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {# --- SEO: Title & description --- #}
  <title>{{ title }}{% if title != "SSI Construction Manager" %} – SSI Construction Manager{% endif %}</title>
  <meta name="description" content="{{ description or 'SSI Construction Manager is the most powerful, affordable tool for construction managers to plan budgets, schedules, purchase orders, and invoices in one place.' }}">

  {# --- Canonical URL --- #}
  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">

  {# --- Favicon --- #}
  <link rel="icon" type="image/png" href="/icon_310x310.png">

  {# --- Open Graph (Facebook / LinkedIn) --- #}
  <meta property="og:site_name" content="SSI Construction Manager">
  <meta property="og:type" content="{% if page.url.startsWith('/posts/') %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or 'The most powerful, affordable tool for managing construction projects.' }}">
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:image" content="{{ metadata.url }}/icon_310x310.png">
  {% if page.date %}<meta property="article:published_time" content="{{ page.date.toISOString() }}">{% endif %}

  {# --- Twitter Card --- #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description or 'The most powerful, affordable tool for managing construction projects.' }}">
  <meta name="twitter:image" content="{{ metadata.url }}/icon_310x310.png">

  {# --- Google Search Console verification ---
       Replace CONTENT with the token from Search Console → Settings → Ownership verification → HTML tag.
       Leave commented out until you have the code. #}
  {# <meta name="google-site-verification" content="REPLACE_WITH_YOUR_TOKEN"> #}

  {# --- Structured data (JSON-LD) --- #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "SSI Construction Manager",
    "url": "{{ metadata.url }}",
    "logo": "{{ metadata.url }}/icon_310x310.png",
    "sameAs": []
  }
  </script>
  {% if page.url.startsWith('/posts/') %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "datePublished": "{{ page.date.toISOString() }}",
    "image": "{{ metadata.url }}/icon_310x310.png",
    "author": { "@type": "Organization", "name": "SSI Construction Manager" },
    "publisher": {
      "@type": "Organization",
      "name": "SSI Construction Manager",
      "logo": { "@type": "ImageObject", "url": "{{ metadata.url }}/icon_310x310.png" }
    },
    "mainEntityOfPage": "{{ metadata.url }}{{ page.url }}"
  }
  </script>
  {% endif %}

  <link rel="stylesheet" href="/styles.css">

  {# --- Google Analytics 4 --- #}
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-HF5TN869RM"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-HF5TN869RM');
  </script>
</head>
<body class="bg-gray-50 text-gray-800">
  <main>
    {{ content | safe }}
  </main>
</body>
</html>